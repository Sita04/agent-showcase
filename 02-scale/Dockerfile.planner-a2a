FROM python:3.13-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    UV_LINK_MODE=copy \
    UV_PRERELEASE=allow

WORKDIR /app

RUN pip install --no-cache-dir uv

COPY pyproject.toml uv.lock ./
RUN uv sync --frozen --no-dev --prerelease allow
RUN uv pip install --python /app/.venv/bin/python "a2a-sdk==0.3.25" "a2a-server==0.1.5"

COPY . .

ENV PYTHONPATH=/app

EXPOSE 8080

CMD ["/app/.venv/bin/python", "agents/planner/a2a_server.py"]
