FROM python:3.13-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    UV_LINK_MODE=copy \
    UV_PRERELEASE=allow

WORKDIR /app

RUN pip install --no-cache-dir uv

COPY pyproject.toml uv.lock ./
RUN uv sync --frozen --no-dev --prerelease allow
RUN uv pip install --python /app/.venv/bin/python "google-adk==2.0.0a2" "fastapi==0.135.2"

COPY . .

ENV PYTHONPATH=/app

EXPOSE 8080

CMD ["/app/.venv/bin/python", "-m", "uvicorn", "app_server:app", "--host", "0.0.0.0", "--port", "8080"]
